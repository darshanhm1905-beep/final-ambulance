# Port for the Node.js backend
PORT=3000

# Set to 1 if deploying to Vercel
VERCEL=0

# PostgreSQL Database URL (required for Render/production)
# Format: postgres://user:password@hostname:5432/dbname
# Leave blank to use local SQLite database
DATABASE_URL=

# (Optional) Frontend URL to allow CORS (for split deployments)
# e.g. https://my-ambulance-frontend.vercel.app
FRONTEND_URL=
